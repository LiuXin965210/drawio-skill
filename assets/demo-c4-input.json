        {"id": "mainframe", "type": "external", "label": "Mainframe Banking", "desc": "Stores core banking data"},
        {"id": "email", "type": "external", "label": "E-mail System", "desc": "Microsoft Exchange"}
      ],
      "relations": [
        {"from": "customer", "to": "ibs", "label": "Views accounts via"},
