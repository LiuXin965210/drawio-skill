      "elements": [
        {"id": "signin", "type": "component", "label": "Sign-In Controller", "tech": "Spring MVC", "desc": "Auth endpoints"},
        {"id": "accounts", "type": "component", "label": "Accounts Controller", "tech": "Spring MVC", "desc": "Account summary endpoints"},
        {"id": "security", "type": "component", "label": "Security Component", "tech": "Spring Bean", "desc": "Credentials check"}
      ],
      "relations": [
        {"from": "signin", "to": "security", "label": "Uses"},
        {"from": "accounts", "to": "security", "label": "Uses"}
