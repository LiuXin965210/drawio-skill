        {"from": "ibs", "to": "email", "label": "Sends e-mail via"}
      ]
    },
    {
      "name": "Containers",
      "elements": [
        {"id": "spa", "type": "container", "label": "Single-Page App", "tech": "React", "desc": "Banking UI in the browser"},
        {"id": "mobile", "type": "container", "label": "Mobile App", "tech": "Flutter", "desc": "iOS / Android client"},
        {"id": "api", "type": "container", "label": "API Application", "tech": "Java / Spring MVC", "desc": "Business logic via JSON/HTTPS API", "children": "Components"},
        {"id": "db", "type": "database", "label": "Database", "tech": "PostgreSQL", "desc": "Accounts, transactions"}
